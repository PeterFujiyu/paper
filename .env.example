# ─── MongoDB ───────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Set to a unique value per Vercel environment (e.g. "production" for the
# production deployment, "preview" for preview deployments).  Tokens are
# bound to this audience, so a JWT signed in a preview environment cannot
# authenticate against the production API even if both share the same
# JWT_SECRET.  Leave unset only in local development.
JWT_AUDIENCE=production

# ─── Auth ──────────────────────────────────────────────────
# Required to register a new account. Leave unset to disable registration entirely.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
INVITE_CODE=replace-with-a-secret-invite-code

# ─── Frontend (Vite) ───────────────────────────────────────
# In development: Vite dev server proxies /api → the Hono server
# In production on Vercel: leave empty (same domain, /api/* handled by serverless)
VITE_API_BASE=/api
