# ─── MongoDB ───────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# ─── Auth ──────────────────────────────────────────────────
# Required to register a new account. Leave unset to disable registration entirely.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
INVITE_CODE=replace-with-a-secret-invite-code

# ─── Frontend (Vite) ───────────────────────────────────────
# In development: Vite dev server proxies /api → the Hono server
# In production on Vercel: leave empty (same domain, /api/* handled by serverless)
VITE_API_BASE=/api
